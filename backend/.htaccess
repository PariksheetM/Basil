Options -Indexes
RewriteEngine On
RewriteBase /fooddash/backend/

# Protect the SQLite database file from direct HTTP access
<FilesMatch "\.(db|sqlite|sqlite3)$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Protect .env file
<FilesMatch "^\.env">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Handle preflight OPTIONS requests
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]
